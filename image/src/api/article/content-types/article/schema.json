{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog article — Markdown content with metadata. 1:1 with website's Article interface."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "author": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "tags": {
      "type": "json",
      "required": true
    },
    "image": {
      "type": "string"
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "draft": {
      "type": "boolean",
      "default": false
    }
  }
}
