    "photoZoom": {
      "type": "decimal",
      "default": 1.0
    },
    "photoPositionX": {
      "type": "integer",
      "default": 50
    },
    "photoPositionY": {
      "type": "integer",
      "default": 50
    },
    "ignore": {
      "type": "boolean",
      "default": false
